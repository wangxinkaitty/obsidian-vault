@article{johnson-lairdLogicProbabilityHuman2015,
  title = {Logic, Probability, and Human Reasoning},
  author = {{Johnson-Laird}, P. N. and Khemlani, Sangeet S. and Goodwin, Geoffrey P.},
  year = 2015,
