@article{aliyyahWhatAffectsEmployee2021,
  title = {What {{Affects Employee Performance}} through {{Work Motivation}}?},
  author = {Aliyyah, Nabilah and Prasetyo, Indra and Rusdiyanto and Endarti, Esa Wahyu and Mardiana, Fitra and Winarko, Ruddy and Chamariyah and Mulyani, Sri and Grahani, Firsty Oktaria and Rochman, Arif Syafi'ur and Kalbuana, Nawang and Hidayat, Widi and Tjaraka, Heru},
  year = 2021,
