@article{ramachandranPsychophysicalInvestigationsNeural2001,
  title = {Psychophysical Investigations into the Neural Basis of Synaesthesia},
  author = {Ramachandran, V. S. and Hubbard, E. M.},
  year = 2001,
  month = may,
  journal = {Proceedings of the Royal Society B: Biological Sciences},
  volume = {268},
