@article{dehaeneVarietiesNumericalAbilities1992,
  title = {Varieties of Numerical Abilities},
  author = {Dehaene, Stanislas},
  year = 1992,
  month = jan,
  journal = {Cognition},
  series = {Numerical {{Cognition}}},
