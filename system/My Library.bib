@article{wangBrainFunctionalNetwork2021,
  title = {Brain Functional Network Modeling and Analysis Based on {{fMRI}}: A Systematic Review},
  shorttitle = {Brain Functional Network Modeling and Analysis Based on {{fMRI}}},
