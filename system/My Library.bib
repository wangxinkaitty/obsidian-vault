@book{cytowicSynesthesiaUnionSenses2002,
  title = {Synesthesia: {{A}} Union of the Senses, 2nd Ed},
  shorttitle = {Synesthesia},
  author = {Cytowic, Richard E.},
  year = 2002,
  series = {Synesthesia: {{A}} Union of the Senses, 2nd Ed},
  pages = {xxv, 394},
  publisher = {Boston Review},
  address = {Cambridge, MA, US},
  doi = {10.7551/mitpress/6590.001.0001},
  abstract = {Most people link senses only by way of metaphoric speech, saying, for example, that red is a "warm" color. But a minority of individuals, known as synsthetes, experience the phrase "I see what you're saying" as literally true. In addition to studying the phenomenon for its own sake, neuroscientists are interested in what synesthesia might reveal about consciousness, the working of nonsynesthetic brains, subjective-objective relations, and the relationship between reason and emotion. The author quickly of disposes of earlier criticisms that the phenomenon cannot be "real," demonstrating that it is brain-based. Following a historical introduction, the author lays out the phenomenology of synesthesia in detail and gives for clinical diagnosis and objective "test of genuineness." The author reviews theories and experimental procedures to localize the plausible level of the neuraxis at which synesthesia operates. In the closing chapters, the author considers synesthetes' personalities, the apparent frequency of the trait among artists, and the subjective and illusory nature of what we take to be objective reality, particularly in the visual realm. (PsycInfo Database Record (c) 2023 APA, all rights reserved)},
  isbn = {978-0-262-03296-4},
  keywords = {Emotions,Intersensory Processes,Neurology,Personality,Reasoning,Sense Organs,Synesthesia},
  file = {C:\Users\wangx\Zotero\storage\8N6XGH66\2002-01685-000.html}
}

@book{cytowicWednesdayIndigoBlue2009,
  title = {Wednesday Is Indigo Blue: {{Discovering}} the Brain of Synesthesia},
  shorttitle = {Wednesday Is Indigo Blue},
  author = {Cytowic, Richard E. and Eagleman, David M.},
  year = 2009,
  series = {Wednesday Is Indigo Blue: {{Discovering}} the Brain of Synesthesia},
  pages = {viii, 309},
  publisher = {Boston Review},
  address = {Cambridge, MA, US},
  abstract = {A person with synesthesia might feel the flavor of food on her fingertips, sense the letter J as shimmering magenta or the number 5 as emerald green, hear and taste her husband's voice as buttery golden brown. Synesthetes rarely talk about their peculiar sensory gift---believing either that everyone else senses the world exactly as they do, or that no one else does. Yet synesthesia occurs in one in twenty people, and is even more common among artists. One famous synesthete was novelist Vladimir Nabokov, who insisted as a toddler that the colors on his wooden alphabet blocks were "all wrong." His mother understood exactly what he meant because she, too, had synesthesia. Nabokov's son Dmitri, who recounts this tale in the afterword to this book, is also a synesthete---further illustrating how synesthesia runs in families. In Wednesday Is indigo Blue, pioneering researcher Richard Cytowic and distinguished neuroscientist David Eagleman explain the neuroscience and genetics behind synesthesia's multisensory experiences. Because synesthesia contradicted existing theory, Cytowic spent twenty years persuading colleagues that it was a real---and important---brain phenomenon rather than a mere curiosity. Today scientists in fifteen countries are exploring synesthesia and how it is changing the traditional view of how the brain works. Cytowic and Eagleman argue that perception is already multisensory, though for most of us its multiple dimensions exist beyond the reach of consciousness. Reality, they point out, is more subjective than most people realize. No mere curiosity, synesthesia is a window on the mind and brain, highlighting the amazing differences in the way people see the world. (PsycInfo Database Record (c) 2025 APA, all rights reserved)},
  isbn = {978-0-262-01279-9},
  keywords = {Brain,Genetics,Neurosciences,Perceptual Motor Processes,Synesthesia},
  file = {C:\Users\wangx\Zotero\storage\NZ9U4NEN\2009-02249-000.html}
}

