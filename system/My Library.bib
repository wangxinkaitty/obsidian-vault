@misc{griffithsWhitherSymbolsEra2025,
  title = {Whither Symbols in the Era of Advanced Neural Networks?},
  author = {Griffiths, Thomas L. and Lake, Brenden M. and McCoy, R. Thomas and Pavlick, Ellie and Webb, Taylor W.},
